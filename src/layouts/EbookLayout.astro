---
import { getCollection } from 'astro:content';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  currentSlug?: string;
}

const { title, description, currentSlug = '' } = Astro.props;

// Fetch collections
const allLessons = await getCollection('lessons');
const allSolutions = await getCollection('solutions');

// Group lessons by session number (1 to 5)
const sessions = [1, 2, 3, 4, 5].map(sNum => {
  const sessionLessons = allLessons
    .filter(l => l.data.session === sNum)
    .sort((a, b) => a.data.order - b.data.order);
  
  // Get a readable title for the session from the first lesson or default
  const sessionTitles = [
    'Cách Collect Data',
    'Google Sheets & Visualize',
    'Làm sạch Data',
    'Visualize trên Looker Studio',
    'Phân tích Trend'
  ];
  
  return {
    number: sNum,
    title: `Buổi ${sNum}: ${sessionTitles[sNum - 1] || ''}`,
    items: sessionLessons.map(l => ({
      title: l.data.type === 'theory' ? '📖 Lý thuyết' : l.data.type === 'lab' ? '💻 Bài thực hành' : '📝 Trắc nghiệm',
      slug: `/lessons/${l.id}`,
      active: `/lessons/${l.id}` === currentSlug,
    }))
  };
});

// Group solutions by session number
const solutions = [1, 2, 3, 4, 5].map(sNum => {
  const sessionSolutions = allSolutions.filter(s => s.data.session === sNum);
  
  return {
    number: sNum,
    title: `Buổi ${sNum}`,
    items: sessionSolutions.map(s => ({
      title: s.data.type === 'lab-solution' ? '🔧 Bài chữa Lab' : '🔑 Đáp án Quiz',
      slug: `/solutions/${s.id}`,
      active: `/solutions/${s.id}` === currentSlug,
    }))
  };
}).filter(s => s.items.length > 0);
---

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | Data Course Ebook</title>
  {description && <meta name="description" content={description} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" default="/favicon.svg" />
</head>
<body>
  <div class="app-container">
    <!-- Top Header -->
    <header class="main-header glass">
      <div class="header-left">
        <button id="menu-toggle" class="icon-btn" aria-label="Toggle Navigation">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
        <a href="/" class="logo">
          <span class="logo-accent">Data</span>Ebook
        </a>
        <span class="badge">Astro Course</span>
      </div>

      <nav class="top-nav">
        <a href="/lessons/session-1/theory" class={`top-nav-link ${currentSlug.startsWith('/lessons/') ? 'active' : ''}`}>📚 Course</a>
        <a href="/solutions/session-1/lab-solution" class={`top-nav-link ${currentSlug.startsWith('/solutions/') ? 'active' : ''}`}>🔑 Solution</a>
        <a href="/references" class={`top-nav-link ${currentSlug.startsWith('/references') ? 'active' : ''}`}>📄 Tài liệu</a>
      </nav>

      <div class="header-right">
        <a href="https://github.com" target="_blank" class="github-link" rel="noreferrer">
          <svg viewBox="0 0 16 16" width="20" height="20" fill="currentColor"><path d="M8 0c4.42 0 8 3.58 8 8 0 3.54-2.29 6.53-5.47 7.59-.4.07-.55-.17-.55-.38 0-.19.01-.82.01-1.49 2.01.37 2.53-.49 2.69-.94.09-.23.48-.94.82-1.13.28-.15.68-.52.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"></path></svg>
        </a>
      </div>
    </header>

    <div class="layout-body">
      <!-- Left Navigation Drawer/Sidebar -->
      <aside class="sidebar glass" id="sidebar">
        <nav class="sidebar-nav">
          {currentSlug.startsWith('/solutions/') ? (
            <div class="sidebar-section solutions-section">
              <h5 class="section-title solutions-title">🔑 BÀI CHỮA & ĐÁP ÁN</h5>
              {solutions.map(solution => (
                <div class="session-block">
                  <div class="session-header solution-session-header">{solution.title}</div>
                  <ul class="session-list">
                    {solution.items.map(item => (
                      <li>
                        <a href={item.slug} class={`sidebar-link solution-link ${item.active ? 'active' : ''}`}>
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          ) : currentSlug.startsWith('/references') ? (
            <div class="sidebar-section">
              <h5 class="section-title" style="color: var(--success);">📄 TÀI LIỆU ĐỌC THÊM</h5>
              <div class="session-block">
                <div class="session-header">Danh mục bài đọc</div>
                <ul class="session-list">
                  <li><a href="#session-1" class="sidebar-link">Buổi 1: API & Khảo sát</a></li>
                  <li><a href="#session-2" class="sidebar-link">Buổi 2: Google Sheets & Viz</a></li>
                  <li><a href="#session-3" class="sidebar-link">Buổi 3: Làm sạch dữ liệu</a></li>
                  <li><a href="#session-4" class="sidebar-link">Buổi 4: Looker Studio BI</a></li>
                  <li><a href="#session-5" class="sidebar-link">Buổi 5: Phân tích Trend</a></li>
                </ul>
              </div>
            </div>
          ) : (
            <div class="sidebar-section">
              <h5 class="section-title">LỘ TRÌNH KHÓA HỌC</h5>
              {sessions.map(session => (
                <div class="session-block">
                  <div class="session-header">{session.title}</div>
                  <ul class="session-list">
                    {session.items.map(item => (
                      <li>
                        <a href={item.slug} class={`sidebar-link ${item.active ? 'active' : ''}`}>
                          {item.title}
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          )}
        </nav>
      </aside>

      <!-- Main Reading Pane -->
      <main class="content-wrapper">
        <article class="content prose fade-in">
          <slot />
        </article>
      </main>
    </div>
  </div>

  <style>
    .app-container {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }

    /* Header CSS */
    .main-header {
      height: var(--header-height);
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 1.5rem;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 50;
      border-bottom: 1px solid var(--border-color);
      box-shadow: var(--shadow-sm);
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .logo {
      font-family: var(--font-display);
      font-size: 1.35rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #ffffff;
      text-shadow: none;
    }

    .logo-accent {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .badge {
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 600;
      background: rgba(0, 242, 254, 0.08);
      border: 1px solid rgba(0, 242, 254, 0.2);
      color: var(--accent-cyan);
      padding: 0.15rem 0.5rem;
      border-radius: var(--radius-full);
      user-select: none;
    }

    .header-right {
      display: flex;
      align-items: center;
    }

    /* Top Navigation in Header */
    .top-nav {
      display: flex;
      gap: 1.5rem;
      align-items: center;
    }

    .top-nav-link {
      font-family: var(--font-display);
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-secondary);
      padding: 0.4rem 0.8rem;
      border-radius: var(--radius-sm);
      transition: all 0.2s;
    }

    .top-nav-link:hover {
      color: #ffffff;
      background: rgba(255, 255, 255, 0.03);
    }

    .top-nav-link.active {
      color: var(--accent-cyan);
      background: rgba(0, 242, 254, 0.06);
      border-bottom: 2px solid var(--accent-cyan);
      border-radius: var(--radius-sm) var(--radius-sm) 0 0;
    }

    .github-link {
      color: var(--text-secondary);
    }
    .github-link:hover {
      color: #ffffff;
      text-shadow: none;
    }

    .icon-btn {
      background: transparent;
      border: none;
      color: var(--text-secondary);
      cursor: pointer;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 0.5rem;
      border-radius: var(--radius-sm);
      transition: all 0.2s;
    }

    .icon-btn:hover {
      background: rgba(255, 255, 255, 0.05);
      color: #ffffff;
    }

    /* Body Layout */
    .layout-body {
      display: flex;
      flex: 1;
      padding-top: var(--header-height);
    }

    /* Sidebar CSS */
    .sidebar {
      width: var(--sidebar-width);
      position: fixed;
      top: var(--header-height);
      bottom: 0;
      left: 0;
      z-index: 40;
      border-right: 1px solid var(--border-color);
      overflow-y: auto;
      padding: 1.5rem 1rem;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .sidebar-nav {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .sidebar-section {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      margin: 0;
    }

    .session-block {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .session-header {
      font-family: var(--font-display);
      font-size: 0.875rem;
      font-weight: 600;
      color: #ffffff;
      padding-left: 0.5rem;
    }

    .session-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
      padding-left: 0.5rem;
      border-left: 1px solid rgba(255, 255, 255, 0.04);
    }

    .sidebar-link {
      display: block;
      padding: 0.4rem 0.75rem;
      font-size: 0.9rem;
      color: var(--text-secondary);
      border-radius: var(--radius-sm);
      transition: all 0.2s;
    }

    .sidebar-link:hover {
      background: rgba(255, 255, 255, 0.03);
      color: #ffffff;
      text-shadow: none;
      padding-left: 0.9rem;
    }

    .sidebar-link.active {
      background: rgba(79, 172, 254, 0.1);
      color: var(--accent-cyan);
      font-weight: 500;
      border-left: 2px solid var(--accent-cyan);
      border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
      padding-left: 0.8rem;
    }

    .sidebar-divider {
      height: 1px;
      background: var(--border-color);
      margin: 0.5rem 0;
    }

    .solutions-title {
      color: #f59e0b;
    }

    .solution-session-header {
      color: #d1d5db;
    }

    .solution-link:hover {
      color: #fbbf24;
    }

    .solution-link.active {
      background: rgba(245, 158, 11, 0.1);
      color: #fbbf24;
      border-left-color: #f59e0b;
    }

    /* Content Pane */
    .content-wrapper {
      flex: 1;
      margin-left: var(--sidebar-width);
      padding: 2rem 2.5rem;
      max-width: 100%;
      min-width: 0;
    }

    .content {
      max-width: 800px;
      margin: 0 auto;
    }

    /* Responsive styles */
    @media (max-width: 900px) {
      .icon-btn {
        display: flex;
      }

      .sidebar {
        transform: translateX(-100%);
        box-shadow: 10px 0 30px rgba(0, 0, 0, 0.5);
      }

      .sidebar.open {
        transform: translateX(0);
      }

      .content-wrapper {
        margin-left: 0;
        padding: 1.5rem;
      }
    }
  </style>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('menu-toggle');
      const sidebar = document.getElementById('sidebar');
      
      if (toggle && sidebar) {
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          sidebar.classList.toggle('open');
        });

        // Close sidebar when clicking outside
        document.addEventListener('click', (e) => {
          if (sidebar.classList.contains('open') && !sidebar.contains(e.target) && e.target !== toggle) {
            sidebar.classList.remove('open');
          }
        });
      }
    });
  </script>
</body>
</html>
