---
import { getCollection, render } from 'astro:content';
import EbookLayout from '../../layouts/EbookLayout.astro';

export async function getStaticPaths() {
  const solutions = await getCollection('solutions');
  return solutions.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EbookLayout title={entry.data.title} description={entry.data.description} currentSlug={`/solutions/${entry.id}`}>
  <Content />
</EbookLayout>
